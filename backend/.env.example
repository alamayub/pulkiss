PORT=3000
# Only this email can call /api/admin/* (must match Firebase user email)
ADMIN_EMAIL=ayub@gmail.com
# Comma-separated origins, e.g. http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173
# Firebase Admin — use ONE of the following (do not commit secrets):
#
# Option A: split fields (no JSON file; good for .env and hosting secrets)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...(use \n for newlines)...\n-----END PRIVATE KEY-----\n"
#
# Option B: full service account as one line (JSON string)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option C: path to the downloaded key file (local only; file is gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# STUN/TURN (optional, JSON array)
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
